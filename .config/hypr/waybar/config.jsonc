// -*- mode: jsonc -*-
{
	"layer": "bottom",
	"position": "bottom",
	"height": 30,
	"widht": 1920,
	"reload_style_on_change": true,

	"include": ["~/.config/hypr/waybar/HYPR-style/modules.jsonc"],

	"modules-left": [
    "custom/user",
		"hyprland/window",
	],
	"modules-center": [
		"hyprland/workspaces",
	],
	"modules-right": [
		"mpd",
		"custom/spacer",
		"custom/updates",
		"group/tray",
		"group/exit",
	],
}
